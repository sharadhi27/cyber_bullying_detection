import pandas as pd
import re
import joblib
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.svm import LinearSVC

# 1. Load the dataset
df = pd.read_csv("data.csv")

# 2. Clean column references
df['text'] = df['tweet_text']
df['label'] = df['cyberbullying_type'].apply(
    lambda x: 0 if x == "not_cyberbullying" else 1
)

# 3. Text cleaning function
def clean(text):
    # Converts to string, lowers case, and removes special characters
    return re.sub(r"[^a-zA-Z ]", "", str(text).lower())

# 4. Apply cleaning
df['text'] = df['text'].apply(clean)

# 5. Vectorize the text data
vectorizer = TfidfVectorizer()
X = vectorizer.fit_transform(df['text'])
y = df['label']

# 6. Train the Support Vector Machine (SVM) Model
model = LinearSVC()
model.fit(X, y)

# 7. Save the trained model and vectorizer
# Note: Creating a 'model' folder if you haven't already, or save them directly
import os
os.makedirs("model", exist_ok=True)

joblib.dump(model, "model/svm_model.pkl")
joblib.dump(vectorizer, "model/tfidf.pkl")

print("Model and Vectorizer trained and saved successfully!")
